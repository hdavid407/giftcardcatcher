{
  "expo": {
    "name": "Telegram Gift Card Buyer",
    "slug": "telegram-buyer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.telegrambuyer.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      },
      "package": "com.telegrambuyer.app"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
