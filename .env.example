# --- Telegram API (get from https://my.telegram.org) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+1234567890

# --- Target Bot ---
TARGET_BOT_USERNAME=@giftcardsellerbot
REFRESH_BUTTON_TEXT=Refresh
PURCHASE_BUTTON_TEXT=Purchase
MENU_BUTTON_TEXT=Main Menu
LISTINGS_BUTTON_TEXT=Listing
FILTERS_BUTTON_TEXT=Filters
GIFTCARDMALL_FILTER_TEXT=GiftCardMall

# --- Polling ---
POLL_INTERVAL_SECONDS=5
MATCH_TIMEOUT_SECONDS=180

# --- Flask Backend ---
FLASK_SECRET_KEY=generate-a-random-secret-key
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# --- Shared API Key (frontend ↔ backend) ---
API_KEY=your-shared-api-key

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
